

<div class="modal fade" id="editMultipleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="editMultipleForm">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title text-dark">Editar Mandriles Seleccionados</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="editIds" />

                    <p>Se editarán <span id="editCount"></span> registros seleccionados.</p>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Mandril</label>
                            <input type="text" class="form-control rounded-pill" id="editMandrilNombre" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Centro de Costos</label>
                            <input type="text" class="form-control rounded-pill" id="editCentroCostos" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Cantidad de Empaque</label>
                            <input type="text" class="form-control rounded-pill" id="editCantidadEmpaque" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Barcode</label>
                            <input type="text" class="form-control rounded-pill" id="editBarcode" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Familia</label>
                            <select class="form-select rounded-pill" id="editFamilia">
                                <option value="">Multiple values</option>
                                <option>33x39.4</option>
                                <option>33x42</option>
                                <option>7x12</option>
                                <option>7.5X14.5</option>
                                <option>37X44</option>
                                <option>37X47</option>
                                <option>11x18</option>
                                <option>13x20</option>
                                <option>13X21</option>
                                <option>24x30</option>
                                <option>16x24</option>
                                <option>7X14</option>
                                <option>11X17</option>
                                <option>9.7X17.6 (AEM)</option>
                                <option>9.7X17.6 (ACM)</option>
                                <option>9.3X17.2</option>
                                <option>8.9X17.2</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Proceso</label>
                            <select class="form-select rounded-pill" id="editProceso">
                                <option value="">Multiple values</option>
                                <option>Coex</option>
                                <option>CHS</option>
                                <option>ACM</option>
                                <option>AEM</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Kanban</label>
                            <input type="text" class="form-control rounded-pill" id="editKanban" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Estación</label>
                            <input type="text" class="form-control rounded-pill" id="editEstacion" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Peso Mínimo</label>
                            <input type="number" step="0.01" class="form-control rounded-pill" id="editPesoMin" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Peso Máximo</label>
                            <input type="number" step="0.01" class="form-control rounded-pill" id="editPesoMax" />
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning rounded-pill">Guardar cambios</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

