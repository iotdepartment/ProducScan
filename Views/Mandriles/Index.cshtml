@{
    ViewData["Title"] = "Mandriles";
    ViewData["Subtitle"] = "Mandriles registrados en el Sistema de escaneo de Inspección.";
}


<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/select/1.7.0/css/select.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css" />

<!-- Partial con modal Create/Edit -->
@await Html.PartialAsync("_CreateEditMandrilModal")

<div class="row mb-3">
    <div class="col-3">
        <button class="btn btn-success rounded-pill w-100"
                data-bs-toggle="modal" data-bs-target="#createEditModal"
                onclick="openCreateModal()">
            <i class="bi bi-plus-circle"></i> Nuevo Mandril
        </button>
    </div>

    <div class="col-9 d-flex justify-content-end gap-2">

        <button id="btnDeleteSelected" class="btn btn-danger rounded-pill">
            <i class="bi bi-trash-fill me-1"></i> Eliminar seleccionados
        </button>

        <button id="btnEditSelected" class="btn btn-warning rounded-pill">
            <i class="bi bi-pencil-square me-1"></i> Editar seleccionados
        </button>

    </div>
</div>

<table id="mandrilesTable" class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Mandril</th>
            @* <th>Centro de Costos</th> *@
            <th>Cantidad de Empaque</th>
            @* <th>Barcode</th> *@
            @* <th>Kanban</th> *@
            <th>Estación</th>
            <th>Familia</th>     
            <th>Proceso</th>     
            @* <th>Peso Min</th>
            <th>Peso Max</th> *@
            <!-- 🆕 NUEVAS COLUMNAS -->
            <th>Imagen</th>
            <th>LTester</th>

            <th class="text-center"></th>

        </tr>
    </thead>
</table>

<!-- Toast único -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 2000">
    <div id="mainToast" class="toast align-items-center border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage">Mensaje aquí</div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deleteForm" asp-action="Delete" method="post">
                <div class="modal-header bg-danger">
                    <h5 class="modal-title text-white">Eliminar Mandril</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="deleteId" name="id" />
                    <p>¿Seguro que deseas eliminar este mandril?</p>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger rounded-pill">Eliminar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@await Html.PartialAsync("_EditMultiplePartial")

@section Scripts {
    <!-- jQuery (primero SIEMPRE) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables núcleo -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <!-- Select -->
    <script src="https://cdn.datatables.net/select/1.7.0/js/dataTables.select.min.js"></script>

    <!-- Buttons núcleo -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>

    <!-- Buttons Bootstrap 5 (ESTE ES EL QUE TE FALTABA EN ORDEN) -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>

    <!-- Buttons extras (opcional) -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <script>
        
        var table;

        $(document).ready(function () {

               table = $('#mandrilesTable').DataTable({
            select: {
                style: 'multi',
                items: 'row',
                selector: 'td:not(:last-child)'
            },

            ajax: {
                url: "/Mandriles/GetMandriles",
                type: "GET",
                datatype: "json"
            },


            columns: [
                { data: "mandrilNombre" },
                { data: "cantidaddeEmpaque" },
                { data: "estacion" },
                { data: "familia" },
                { data: "proceso" },
                {
                    data: "imagen",
                    render: function (data) {
                        if (!data) {
                            return `<div class="text-center text-muted">Sin imagen</div>`;
                        }

                        return `
                            <div style="display:flex; justify-content:center; width:100%;">
                                <img src="/images/mandriles/${data}"
                                     class="img-thumbnail shadow-sm"
                                     style="width:55px; height:55px; object-fit:cover; border-radius:8px;">
                            </div>
                        `;
                    }
                },
                {
                    data: "lTester",
                    render: function (data) {
                        if (data === true) return "<span class='badge bg-success'>Sí</span>";
                        if (data === false) return "<span class='badge bg-danger'>No</span>";
                        return "<span class='badge bg-secondary'>N/A</span>";
                    }
                },

                {
                    data: "id",
                    className: "text-center",
                    render: function (data, type, row) {

                        return `
                            <button class="btn btn-sm btn-warning rounded-pill"
                                onclick="openEditModal(
                                    ${data},
                                    '${row.mandrilNombre}',
                                    '${row.centrodeCostos}',
                                    '${row.cantidaddeEmpaque}',
                                    '${row.barcode}',
                                    '${row.kanban}',
                                    '${row.estacion ?? ""}',
                                    '${row.familia ?? ""}',
                                    '${row.proceso ?? ""}',
                                    '${row.pesomin ?? ""}',
                                    '${row.pesomax ?? ""}',
                                    '${row.imagen ?? ""}',
                                    ${row.lTester === true ? "'true'" : row.lTester === false ? "'false'" : "''"}
                                )">
                                <i class="bi bi-pencil-fill"></i>
                            </button>
                        `;
                    }
                }
            ],

            columnDefs: [
                { className: "text-center", targets: "_all" }
            ],

            pageLength: 10,
            lengthMenu: [10, 20, 50, 100, 200],

            ordering: false,

            language: { url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" }
        });

        // 🟥 Eliminar seleccionados
        $("#btnDeleteSelected").click(function () {
            const rows = table.rows({ selected: true }).data();
            if (!rows.length) {
                alert("Selecciona al menos un registro");
                return;
            }

            const ids = rows.pluck("id").toArray();
            $("#deleteId").val(ids.join(","));
            $("#deleteModal .modal-body p").text(
                `¿Seguro que deseas eliminar ${rows.length} registros seleccionados?`
            );

            $("#deleteModal").modal("show");
        });

        // 🟨 Editar seleccionados
        $("#btnEditSelected").click(function () {
            openEditMultipleModal();
        });


        const editFields = {
            editMandrilNombre: "mandrilNombre",
            editCentroCostos: "centrodeCostos",
            editCantidadEmpaque: "cantidaddeEmpaque",
            editBarcode: "barcode",
            editKanban: "kanban",
            editEstacion: "estacion",
            editFamilia: "familia",
            editProceso: "proceso",
            editPesoMin: "pesoMin",
            editPesoMax: "pesoMax"
        };

        function setMultiValue(fieldId, values, isSelect = false) {
            const clean = [...new Set(values.filter(v => v != null && v !== ""))];

            if (clean.length === 1) {
                $("#" + fieldId).val(clean[0]);
            } else if (clean.length > 1) {
                if (isSelect) {
                    $("#" + fieldId).val("");
                    $("#" + fieldId + " option:first").text("Multiple values");
                } else {
                    $("#" + fieldId).val("").attr("placeholder", "Multiple values");
                }
            } else {
                $("#" + fieldId).val("");
            }
        }

        function openEditMultipleModal() {

            const rows = table.rows({ selected: true }).data();

            if (!rows.length) {
                alert("Selecciona al menos un registro");
                return;
            }

            const ids = rows.pluck("id").toArray();
            $("#editIds").val(ids.join(","));
            $("#editCount").text(rows.length);

            for (const fieldId in editFields) {
                const columnName = editFields[fieldId];
                const values = rows.pluck(columnName).toArray();
                const isSelect = $("#" + fieldId).is("select");

                setMultiValue(fieldId, values, isSelect);
            }

            $("#editMultipleModal").modal("show");
        }

        $("#editMultipleForm").submit(function (e) {
            e.preventDefault();

            const payload = {
                ids: $("#editIds").val().split(",")
            };

            for (const fieldId in editFields) {
                const dtoName = editFields[fieldId];
                const value = $("#" + fieldId).val();
                payload[dtoName] = value !== "" ? value : null;
            }

            $.ajax({
                type: "POST",
                url: "/Mandriles/EditMultiple",
                contentType: "application/json",
                data: JSON.stringify(payload),
                success: function (res) {
                    $("#editMultipleModal").modal("hide");
                    showToast(res.message, true);
                    table.ajax.reload(null, false);
                },
                error: function (xhr) {
                    showToast("Error: " + xhr.responseText, false);
                }
            });
        });


        });
             

        /* ============================
            SUBMIT CREATE / EDIT
        ============================ */
               $("#createEditForm").submit(function (e) {
            e.preventDefault();

            var formData = new FormData(this);

            $.ajax({
                type: "POST",
                url: $(this).attr("action"),
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        $('#createEditModal').modal('hide');
                        showToast(res.message, true);
                        table.ajax.reload(null, false);
                    } else {
                        showToast(res.message, false);
                    }
                }
            });
        });

        /* ============================
            SUBMIT DELETE
        ============================ */
        $("#deleteForm").submit(function (e) {
            e.preventDefault();
            var ids = $("#deleteId").val().split(","); 

            $.ajax({
                type: "POST",
                url: "/Mandriles/DeleteMultiple",
                contentType: "application/json",
                data: JSON.stringify(ids),
                success: function (res) {
                    if (res.message) {
                        $('#deleteModal').modal('hide');
                        showToast(res.message, true);
                        table.ajax.reload(null, false);
                    } else {
                        showToast("Error al eliminar registros", false);
                    }
                },
                error: function (xhr) {
                    showToast("Error: " + xhr.responseText, false);
                }
            });
        });


        /* ============================
           MODAL ELIMINAR
        ============================ */
        function openDeleteModal(id) {
            document.getElementById("deleteId").value = id;
            $('#deleteModal').modal('show');
        }

        /* ============================
           RESET AUTOMÁTICO DEL MODAL
        ============================ */
        $('#createEditModal').on('hidden.bs.modal', function () {
            $(this).find('form')[0].reset();
            $(this).find('form').removeClass('was-validated');
        });

        /* ============================
           TOAST
        ============================ */
        function showToast(message, isSuccess = true) {
            const toastEl = document.getElementById("mainToast");
            const toastBody = document.getElementById("toastMessage");

            toastEl.classList.remove("text-bg-success", "text-bg-danger");
            toastEl.classList.add(isSuccess ? "text-bg-success" : "text-bg-danger");

            toastBody.innerText = message;

            var toast = new bootstrap.Toast(toastEl);
            toast.show();
        }

    </script>
}