@{
    ViewData["Title"] = "Mesas";
    ViewData["Subtitle"] = "Listado de Mesas del Área de Inspección.";

}

<div class="container mt-4">

    <table id="mesasTable" class="table table-striped table-bordered w-100">
        <thead class="table-dark">
            <tr>
                <th class="text-center">Nombre</th>
                <th class="text-center">Número Mesa</th>
                <th class="text-center">Meta</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
    </table>
</div>

<!-- Modal Editar Meta -->
<div class="modal fade" id="editMetaModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editMetaForm">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title ">Editar Meta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="idMesa" />

                    <label class="form-label">Meta</label>
                    <input type="number" class="form-control rounded-pill" id="metaValue" min="0" />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning rounded-pill">Guardar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>
@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/select/1.7.0/css/select.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/select/1.7.0/js/dataTables.select.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

        var table = $("#mesasTable").DataTable({
            ajax: {
                url: "/Mesas/GetMesas",
                type: "GET"
            },
            columns: [
                { data: "mesas" },
                { data: "numerodeMesa" },
                { data: "meta" },
                {
                    data: "idMesa",
                    render: function (id) {
                        return `
                            <button class="btn btn-warning btn-sm btnEditar rounded-pill" data-id="${id}">
                                Editar Meta
                            </button>`;
                    }
                }
            ],
            columnDefs: [
                { className: "text-center", targets: "_all" }
            ],
            order: [[1, "asc"]],
            language: {
                url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
            }
        });

        function mostrarToast(tipo, mensaje) {
            var id = "toast-" + Date.now();

            $("#toastContainer").append(`
                <div id="${id}" class="toast text-bg-${tipo} border-0" role="alert">
                    <div class="d-flex">
                        <div class="toast-body">${mensaje}</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            `);

            var toast = new bootstrap.Toast(document.getElementById(id), { delay: 3500 });
            toast.show();
        }
            // ============================
            // Abrir modal de edición
            // ============================
            $(document).on("click", ".btnEditar", function () {
                let id = $(this).data("id");
                $("#idMesa").val(id);

                let row = table.row($(this).parents("tr")).data();
                $("#metaValue").val(row.meta);

                $("#editMetaModal").modal("show");
            });

            // ============================
            // Guardar cambios
            // ============================
                   $("#editMetaForm").submit(function (e) {
            e.preventDefault();

            $.post("/Mesas/EditMeta",
                {
                    idMesa: $("#idMesa").val(),
                    meta: $("#metaValue").val()
                },
                function (res) {
                    if (res.success) {
                        $("#editMetaModal").modal("hide");
                        mostrarToast("success", "Meta actualizada correctamente");
                        table.ajax.reload(null, false);
                    } else {
                        mostrarToast("danger", res.message);
                    }
                }
            ).fail(function (xhr) {
                mostrarToast("danger", "Error al actualizar: " + xhr.responseText);
            });
        });

        });
    </script>
}