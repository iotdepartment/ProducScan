@model List<ProducScan.ViewModels.ProduccionDetalleViewModel>

@{
    ViewData["Title"] = "Producción por TM";
}

<div class="card mb-3 shadow-sm border-0 rounded-4">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h5 class="card-title">Producción del día</h5>
            <p class="card-text">
                <strong>Fecha laboral:</strong> @ViewBag.FechaLaboral
            </p>
            <p class="card-text">
                <strong>Team Member:</strong> @ViewBag.Usuario
            </p>
        </div>
        <div class="tm-photo text-center">
            <img src="@ViewBag.FotoUrl"
                 alt="Foto de @ViewBag.Usuario"
                 class="rounded-circle shadow-sm"
                 style="width:80px;height:80px;object-fit:cover;border:3px solid #fff;" />
        </div>
    </div>
</div>

<div class="mb-3">
    <button id="btnEditMultiple" class="btn btn-warning rounded-pill">Editar seleccionados</button>
    <button id="btnDeleteMultiple" class="btn btn-danger rounded-pill">Eliminar seleccionados</button>
</div>

<table id="produccionTable" class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Fecha laboral</th>
            <th>Fecha real</th>
            <th>Hora</th>
            <th>Mesa</th>
            <th>Turno</th>
            <th>Mandrel</th>
            <th>Piezas</th>
            <th>Segundos/Pieza</th>
        </tr>
    </thead>
</table>

<!-- Modal editar múltiples -->
<div class="modal fade" id="editMultipleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="editMultipleForm">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title text-dark">Editar registros seleccionados</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="editIds" />
                    <p>Se editarán <span id="editCount"></span> registros seleccionados.</p>

                    <div class="row g-3">

                        <div class="col-md-6 position-relative">
                            <label class="form-label">Team Member</label>
                            <input type="text" class="form-control rounded-pill" id="editTM" autocomplete="off" />
                            <div id="tmSuggestions" class="list-group position-absolute w-100"></div>
                        </div>

                        <!-- MESA -->
                        <div class="col-md-6">
                            <label class="form-label">Mesa</label>
                            <select id="editMesa" class="form-select rounded-pill">
                                <option value="">Selecciona mesa</option>
                                @for (int i = 1; i <= 25; i++)
                                {
                                    <option value="@i">Mesa @i</option>
                                }
                            </select>
                        </div>

                        <!-- TURNO -->
                        <div class="col-md-6">
                            <label class="form-label">Turno</label>
                            <select id="editTurno" class="form-select rounded-pill">
                                <option value="">Selecciona turno</option>
                                <option value="1">Turno 1</option>
                                <option value="2">Turno 2</option>
                                <option value="3">Turno 3</option>
                            </select>
                        </div>

                        <!-- MANDRIL -->
                        <div class="col-md-6 position-relative">
                            <label class="form-label">Mandril</label>
                            <input type="text" id="editMandril" class="form-control rounded-pill" autocomplete="off" />
                            <div id="mandrilSuggestions" class="list-group position-absolute w-100"></div>
                        </div>

                        <!-- PIEZAS -->
                        <div class="col-md-6">
                            <label class="form-label">Piezas</label>
                            <input type="number" id="editPiezas" class="form-control rounded-pill" min="0" />
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning rounded-pill">Guardar cambios</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal eliminar múltiples / individual -->
<div class="modal fade" id="deleteMultipleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deleteMultipleForm">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Eliminar registros</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="deleteIds" />
                    <p>Se eliminarán <span id="deleteCount"></span> registros. ¿Deseas continuar?</p>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger rounded-pill">Eliminar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalCrud" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="modalContent">

        </div>
    </div>
</div>


<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>
@await Html.PartialAsync("_EditMultipleProduccion")

@section Scripts {

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/select/1.7.0/css/select.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css">

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/select/1.7.0/js/dataTables.select.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            /* ============================
               AUTOCOMPLETE MANDRIL
            ============================ */
            $(document).on("keyup", "#editMandril", function () {
                let query = $(this).val();

                if (query.length < 2) {
                    $("#mandrilSuggestions").empty();
                    return;
                }

                $.get("/PiezasEscaneadas/BuscarMandrels", { term: query }, function (data) {
                    let s = $("#mandrilSuggestions").empty();

                    if (data.length === 0) {
                        s.append('<div class="list-group-item">Sin resultados</div>');
                    } else {
                        data.forEach(m => {
                            s.append(`<button class="list-group-item list-group-item-action mandril-option">${m}</button>`);
                        });
                    }
                });
            });

            /* ============================
                AUTOCOMPLETE TEAM MEMBER
            ============================ */
            $(document).on("keyup", "#editTM", function () {
                let query = $(this).val();

                if (query.length < 2) {
                    $("#tmSuggestions").empty();
                    return;
                }

                $.get("/PiezasEscaneadas/BuscarTM", { term: query }, function (data) {
                    let s = $("#tmSuggestions").empty();

                    if (data.length === 0) {
                        s.append('<div class="list-group-item">Sin resultados</div>');
                    } else {
                        data.forEach(t => {
                            s.append(`<button class="list-group-item list-group-item-action tm-option">${t}</button>`);
                        });
                    }
                });
            });

            $(document).on("click", ".tm-option", function () {
                $("#editTM").val($(this).text());
                $("#tmSuggestions").empty();
            });

            $(document).on("click", ".mandril-option", function () {
                $("#editMandril").val($(this).text());
                $("#mandrilSuggestions").empty();
            });

            /* ============================
               DATATABLE AJAX
            ============================ */
            var table = $('#produccionTable').DataTable({
                       select: {
            style: 'multi',
            items: 'row',
            selector: 'td:not(:last-child)'
        },
                ajax: {
                    url: "/PiezasEscaneadas/GetProduccionAjax",
                    type: "GET",
                    data: {
                        usuario: "@ViewBag.Usuario",
                        fechaLaboral: "@ViewBag.FechaLaboral"
                    }
                },
                columns: [
                    {
                        data: "fechaLaboral",
                        render: d => new Date(d).toISOString().split("T")[0]
                    },
                    { data: "fechaReal" },
                    { data: "hora" },
                    { data: "nuMesa" },
                    { data: "turno" },
                    { data: "mandrel" },
                    { data: "numeroDePiezas" },
                    { data: "segundosPorPieza" }
                ],
                ordering: false,
                paging: true,
                searching: true,
                info: true,
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                }
            });

            /* ============================
               BOTONES
            ============================ */
            $("#btnEditMultiple").on("click", openEditMultipleModal);
            $("#btnDeleteMultiple").on("click", openDeleteMultipleModal);

            /* ============================
               ELIMINAR INDIVIDUAL
            ============================ */
            $(document).on("click", ".btnEliminar", function () {
                const id = $(this).data("id");
                $("#deleteIds").val(id);
                $("#deleteCount").text(1);
                $("#deleteMultipleModal").modal("show");
            });

            /* ============================
               ELIMINAR MÚLTIPLES
            ============================ */
            function openDeleteMultipleModal() {
                const rows = table.rows({ selected: true }).data();

                if (!rows.length) {
                    mostrarToast("danger", "Selecciona al menos un registro");
                    return;
                }

                const ids = rows.pluck("id").toArray();
                $("#deleteIds").val(ids.join(","));
                $("#deleteCount").text(rows.length);
                $("#deleteMultipleModal").modal("show");
            }

            $("#deleteMultipleForm").submit(function (e) {
                e.preventDefault();

                const ids = $("#deleteIds").val().split(",");

                $.ajax({
                    type: "POST",
                    url: "/PiezasEscaneadas/DeleteMultiple",
                    contentType: "application/json",
                    data: JSON.stringify(ids),
                    success: function (res) {
                        $("#deleteMultipleModal").modal("hide");
                        mostrarToast("success", res.message);
                        table.ajax.reload(null, false);
                    }
                });
            });

            /* ============================
               SET MULTI VALUE (ESTILO MANDRILES)
            ============================ */
            function setMultiValue(fieldId, values) {
                const clean = [...new Set(values.filter(v => v != null && v !== ""))];

                if (clean.length === 1) {
                    $("#" + fieldId).val(clean[0]);
                } else if (clean.length > 1) {
                    $("#" + fieldId).val("");
                } else {
                    $("#" + fieldId).val("");
                }
            }

            /* ============================
               MESA NORMALIZADA
            ============================ */
            function setMultiValueMesa(values) {
                const normalized = values.map(v => {
                    if (!v) return "";
                    return v.replace("MESA#", "").trim();
                });

                const clean = [...new Set(normalized.filter(v => v !== ""))];

                if (clean.length === 1) {
                    $("#editMesa").val(clean[0]);
                } else {
                    $("#editMesa").val("");
                }
            }

            /* ============================
               ABRIR MODAL EDICIÓN MÚLTIPLE
            ============================ */
            function openEditMultipleModal() {
                const rows = table.rows({ selected: true }).data();

                if (!rows.length) {
                    mostrarToast("danger", "Selecciona al menos un registro");
                    return;
                }

                const ids = rows.pluck("id").toArray();
                $("#editIds").val(ids.join(","));
                $("#editCount").text(rows.length);

                setMultiValue("editTM", rows.pluck("tm").toArray());
                setMultiValueMesa(rows.pluck("nuMesa").toArray());
                setMultiValue("editTurno", rows.pluck("turno").toArray());
                setMultiValue("editMandril", rows.pluck("mandrel").toArray());
                setMultiValue("editPiezas", rows.pluck("numeroDePiezas").toArray());

                $("#editMultipleModal").modal("show");
            }



            /* ============================
               SUBMIT EDICIÓN MÚLTIPLE
            ============================ */
            $("#editMultipleForm").submit(function (e) {
                e.preventDefault();

                const payload = {
                    ids: $("#editIds").val().split(",")
                };
                payload["Tm"] = $("#editTM").val() || null;
                payload["NuMesa"] = $("#editMesa").val() ? "MESA#" + $("#editMesa").val() : null;
                payload["Turno"] = $("#editTurno").val() || null;
                payload["Mandrel"] = $("#editMandril").val() || null;
                payload["Ndpiezas"] = $("#editPiezas").val() || null;

                $.ajax({
                    type: "POST",
                    url: "/PiezasEscaneadas/EditMultiple",
                    contentType: "application/json",
                    data: JSON.stringify(payload),
                    success: function (res) {
                        $("#editMultipleModal").modal("hide");
                        mostrarToast("success", res.message);
                        table.ajax.reload(null, false);
                    }
                });
            });

            /* ============================
               TOAST
            ============================ */
            function mostrarToast(tipo, mensaje) {
                var id = "toast-" + Date.now();
                $("#toastContainer").append(`
                    <div id="${id}" class="toast text-bg-${tipo} border-0">
                        <div class="d-flex">
                            <div class="toast-body">${mensaje}</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                `);

                var toast = new bootstrap.Toast(document.getElementById(id), { delay: 4000 });
                toast.show();
            }

        });
    </script>
}